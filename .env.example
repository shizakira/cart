# App
APP_NAME=cart-service
APP_VERSION=v1.0.0

# Logger
LOGGER_LEVEL=debug
LOGGER_PRETTY_CONSOLE=true

# HTTP
HTTP_PORT=8082
HTTP_ADDR=0.0.0.0

# Postgres
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
POSTGRES_DB_NAME=postgres

# Product service
PRODUCT_SERVICE_BASE_URL=http://route256.pavl.uk:8080
PRODUCT_SERVICE_TOKEN=testtoken
PRODUCT_SERVICE_TIMEOUT=3s

# Migrate
MIGRATE_PATH=./migration/postgres
DB_MIGRATE_URL=postgres://user:pass@localhost:5433/postgres?sslmode=disable
